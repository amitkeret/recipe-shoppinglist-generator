{
  "name": "recipe-shoppinglist-generator",
  "version": "0.1.0",
  "description": "recipe-shoppinglist-generator",
  "main": "index.html",
  "dependencies": {
    "http-server": "*"
  },
  "devDependencies": {
    "coffeescript": "^2.3.2",
    "concurrently": "^4.1.0",
    "pug": "^2.0.3",
    "pug-cli": "^1.0.0-alpha6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amitkeret/recipe-shoppinglist-generator.git"
  },
  "scripts": {
    "watch-coffee": "npx coffee -o dist/ -cmw src/recipes.coffee",
    "build:js": "coffee -o dist/ -c src/recipes.coffee",
    "watch-jade": "npx pug -o dist/ -Pw src/index.jade",
    "build:html": "pug -o dist/ -P src/index.jade",
    "dev": "concurrently --kill-others \"npm:watch-*\"",
    "build": "npm run build:js && npm run build:html",
    "start": "http-server ./dist"
  },
  "author": "amitkeret",
  "license": "MIT",
  "homepage": "https://github.com/amitkeret/recipe-shoppinglist-generator#readme"
}
